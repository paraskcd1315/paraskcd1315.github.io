# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js
worker/node_modules

# cloudflare worker local state
worker/.wrangler
worker/.dev.vars

# testing
/coverage

# production
/build

# misc
.DS_Store

# env files (CRA bakes these into the static bundle — never commit any)
.env
.env.*
!.env.example

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# legacy local config
config.js

# secrets / private keys (defensive — these should never end up in a static-site repo)
*.pem
*.key
*.p12
*.pfx
id_rsa*
secrets.*
.aws/

# editor folders
.idea/
.vscode/
